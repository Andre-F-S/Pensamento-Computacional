#include <Keypad.h>

const byte LINHAS = 4;
const byte COLUNAS = 4;

char teclas[LINHAS][COLUNAS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

byte pinosLinhas[LINHAS] = {9, 8, 7, 6};
byte pinosColunas[COLUNAS] = {5, 4, 3, 2};

Keypad teclado = Keypad(
  makeKeymap(teclas),
  pinosLinhas,
  pinosColunas,
  LINHAS,
  COLUNAS
);

char ultimaTecla = '\0';
int contador = 0;

String letras[] = {
  "", "", "ABC", "DEF", "GHI",
  "JKL", "MNO", "PQRS", "TUV", "WXYZ"
};

void setup() {
  Serial.begin(9600);
}

void loop() {
  char tecla = teclado.getKey();

  if (tecla >= '2' && tecla <= '9') {

    if (tecla == ultimaTecla) {
      contador++;
    } else {
      contador = 1;
      ultimaTecla = tecla;
    }

    int indiceTecla = tecla - '0';

    int posicao = (contador - 1) % letras[indiceTecla].length();

    char letra = letras[indiceTecla][posicao];

    Serial.print("Letra atual: ");
    Serial.println(letra);
  }
}
